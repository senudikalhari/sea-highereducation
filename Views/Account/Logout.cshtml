@{
    ViewData["Title"] = "Logout";
}

<div class="d-flex justify-content-center align-items-center vh-100">

    <div class="card text-center p-5 shadow-lg"
         style="width:400px; background:#1e293b; color:white; border-radius:15px;">

        <h2 class="mb-3">👋 Logged Out</h2>

        <p class="text-muted">
            You have successfully logged out of the system.
        </p>

        <hr style="background:#334155;" />

        <a href="/Account/Login" class="btn btn-primary w-100 mt-3">
            🔐 Login Again
        </a>

    </div>

</div>

<script>
    
    setTimeout(() => {
        window.location.href = "/Account/Login";
    }, 3000);
</script>