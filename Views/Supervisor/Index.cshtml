@model IEnumerable<BlindMatchPAS_Final.Models.Project>

<h2 class="mb-4">👨‍🏫 Blind Match Dashboard</h2>

<!--SEARCH + FILTER -->
<form method="get" class="row mb-4 p-3 rounded-4 shadow"
      style="background: rgba(30,41,59,0.9); backdrop-filter: blur(10px);">

    <!-- SEARCH -->
    <div class="col-md-4 mb-2">
        <input type="text" name="search"
               value="@Context.Request.Query["search"]"
               class="form-control"
               placeholder="🔍 Search projects..." />
    </div>

    <!-- STATUS -->
    <div class="col-md-3 mb-2">
        <select name="status" class="form-control">
            <option value="">All Status</option>
            <option selected="@(Context.Request.Query["status"] == "Pending")">Pending</option>
            <option selected="@(Context.Request.Query["status"] == "UnderReview")">UnderReview</option>
            <option selected="@(Context.Request.Query["status"] == "Reviewed")">Reviewed</option>
            <option selected="@(Context.Request.Query["status"] == "Matched")">Matched</option>
        </select>
    </div>

    <!-- AREA -->
    <div class="col-md-3 mb-2">
        <select name="area" class="form-control">
            <option value="">All Areas</option>
            <option value="AI" selected="@(Context.Request.Query["area"] == "AI")">AI</option>
            <option value="Web" selected="@(Context.Request.Query["area"] == "Web")">Web</option>
            <option value="Security" selected="@(Context.Request.Query["area"] == "Security")">Security</option>
        </select>
    </div>

    <!-- BUTTON -->
    <div class="col-md-2 mb-2">
        <button class="btn btn-primary w-100">Apply</button>
    </div>

</form>

<!--GRID -->
<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">

            <div class="card shadow-lg border-0 rounded-4 h-100"
                 style="background: rgba(255,255,255,0.05); backdrop-filter: blur(12px); color:white;">

                <!-- HEADER -->
                <div class="card-header border-0"
                     style="background: rgba(0,0,0,0.4); font-weight:bold;">
                    📌 @item.Title
                </div>

                <!-- BODY -->
                <div class="card-body">

                    <p class="text-light small">
                        @item.Abstract
                    </p>

                    <p><strong>⚙ Tech:</strong> @item.TechStack</p>
                    <p><strong>🔬 Area:</strong> @item.ResearchArea</p>

                    <!-- STATUS -->
                    <p>
                        <strong>Status:</strong>
                        @if (item.Status == "Matched")
                        {
                            <span class="badge bg-success">✅ Matched</span>
                        }
                        else if (item.Status == "UnderReview")
                        {
                            <span class="badge bg-warning text-dark">🔍 Under Review</span>
                        }
                        else if (item.Status == "Reviewed")
                        {
                            <span class="badge bg-info text-dark">📝 Reviewed</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">⏳ Pending</span>
                        }
                    </p>

                    <!-- STUDENT -->
                    <p>
                        <strong>👨‍🎓 Student:</strong><br />
                        @if (item.IsMatched)
                        {
                            <span class="text-success">@item.StudentEmail</span>
                        }
                        else
                        {
                            <span class="text-muted">🔒 Hidden</span>
                        }
                    </p>

                    <!-- PDF -->
                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        <a href="@item.FilePath" target="_blank"
                           class="btn btn-outline-info btn-sm w-100 mb-2">
                            📄 View Proposal
                        </a>
                    }

                </div>

                <!-- ACTIONS -->
                <div class="card-footer border-0 bg-transparent">

                    @if (item.Status == "Pending")
                    {
                        <a asp-action="Interested" asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm w-100 mb-2">
                            ⭐ Interested
                        </a>
                    }

                    @if (item.Status == "UnderReview")
                    {
                        <a asp-action="Review" asp-route-id="@item.Id"
                           class="btn btn-primary btn-sm w-100 mb-2">
                            ✍ Review
                        </a>

                        <a asp-action="ConfirmMatch" asp-route-id="@item.Id"
                           class="btn btn-success btn-sm w-100 mb-2">
                            ✅ Confirm Match
                        </a>
                    }

                    @if (item.Status == "Reviewed")
                    {
                        <a asp-action="ConfirmMatch" asp-route-id="@item.Id"
                           class="btn btn-success btn-sm w-100 mb-2">
                            ✅ Confirm Match
                        </a>
                    }

                    @if (item.Status == "Matched")
                    {
                        <div class="text-success text-center fw-bold">
                            ✔ Already Matched
                        </div>
                    }

                    @if (item.Status != "Matched")
                    {
                        <a asp-action="Reject" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm w-100">
                            ❌ Reject
                        </a>
                    }

                </div>

            </div>

        </div>
    }

</div>