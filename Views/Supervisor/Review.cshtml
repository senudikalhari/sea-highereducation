@model BlindMatchPAS_Final.Models.Project

<h2 class="mb-4">📝 Review Project</h2>

<div class="card shadow-lg border-0 rounded-4 p-4"
     style="background: rgba(255,255,255,0.05); backdrop-filter: blur(12px); color:white;">

    <h4>📌 @Model.Title</h4>

    <p>@Model.Abstract</p>
    <p><strong>Tech:</strong> @Model.TechStack</p>
    <p><strong>Area:</strong> @Model.ResearchArea</p>

    @if (!string.IsNullOrEmpty(Model.FilePath))
    {
        <a href="@Model.FilePath" target="_blank"
           class="btn btn-outline-info mb-3">
            📄 View PDF
        </a>
    }

    <form asp-action="Review" method="post">

        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-3">
            <label>💬 Feedback</label>
            <textarea asp-for="Feedback" class="form-control" required></textarea>
        </div>

        <div class="mb-3">
            <label>🤖 Score</label>
            <input asp-for="Score" type="number" class="form-control" min="0" max="100" />
        </div>

        <button class="btn btn-primary w-100">💾 Save Review</button>

    </form>

    <a asp-action="ConfirmMatch" asp-route-id="@Model.Id"
       class="btn btn-success w-100 mt-3">
        ✅ Confirm Match
    </a>

</div>