@model BlindMatchPAS_Final.Models.Project

<h2 class="mb-4">❌ Reject Project</h2>

<div class="card shadow-lg border-0 rounded-4 p-4"
     style="background: rgba(255,255,255,0.05); backdrop-filter: blur(12px); color:white;">

    <h4>📌 @Model.Title</h4>

    <p class="text-light">@Model.Abstract</p>

    <form asp-action="Reject" method="post">

        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label">📝 Reason for rejection</label>
            <textarea name="reason"
                      class="form-control"
                      rows="4"
                      required
                      placeholder="Explain why this project is rejected..."></textarea>
        </div>

        <div class="d-flex gap-2">

            <button class="btn btn-danger w-100">
                ❌ Confirm Reject
            </button>

            <a asp-action="Index" class="btn btn-secondary w-100">
                ⬅ Cancel
            </a>

        </div>

    </form>

</div>