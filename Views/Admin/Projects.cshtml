@model IEnumerable<BlindMatchPAS_Final.Models.Project>

<h3>📁 All Projects</h3>

<table class="table table-dark table-striped">
    <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Student</th>
        <th>Supervisor</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Title</td>
            <td>@p.Status</td>
            <td>@p.StudentEmail</td>
            <td>@p.SupervisorEmail</td>
        </tr>
    }

</table>